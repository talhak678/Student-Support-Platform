// ================================================================
// Student Support Platform (UK) — Prisma Schema
// Tech: Next.js + NextAuth + PostgreSQL (Neon) + Cloudinary + Stripe/PayPal
// ================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  // Connection URLs are managed via prisma.config.ts (Prisma v7)
}

// ================================================================
// ENUMS
// ================================================================

enum UserRole {
  STUDENT
  ADMIN
  SUPER_ADMIN
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  ACTION_REQUIRED
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentProvider {
  STRIPE
  PAYPAL
}

enum ServiceType {
  CV_STRATEGY
  EDUCATION_CONSULTANCY
  VISA_GUIDANCE
  JOB_PLACEMENT
  ACCOMMODATION_BOOKING
  GENERAL_SUPPORT
}

enum AccommodationStatus {
  PENDING
  SEARCHING
  FOUND
  CONFIRMED
  CANCELLED
}

enum DocumentType {
  CV
  PASSPORT
  TRANSCRIPT
  VISA
  REFERENCE_LETTER
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  CONVERTED
  ARCHIVED
}

enum NotificationType {
  APPLICATION_UPDATE
  TICKET_REPLY
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  GENERAL
}

// ================================================================
// AUTH — NextAuth.js Required Tables
// See: https://authjs.dev/reference/adapter/prisma
// ================================================================

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ================================================================
// USER — Core User Account
// ================================================================

/// Shared user for Student, Admin & Super Admin roles
model User {
  id              String    @id @default(cuid())
  name            String?
  email           String    @unique
  emailVerified   DateTime?
  password        String?   // Hashed (nullable for OAuth providers)
  image           String?   // Profile photo (Cloudinary URL)
  role            UserRole  @default(STUDENT)
  isActive        Boolean   @default(true)

  // NextAuth relations
  accounts        Account[]
  sessions        Session[]

  // App relations
  studentProfile  StudentProfile?
  documents       Document[]
  applications    ServiceApplication[]
  supportTickets  SupportTicket[]
  ticketReplies   TicketReply[]
  payments        Payment[]
  adminNotes      AdminNote[]   @relation("AdminWhoWroteNote")
  notifications   Notification[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([email])
  @@index([role])
}

// ================================================================
// STUDENT PROFILE — Onboarding Form Data
// ================================================================

/// Stores all onboarding form fields for a student
model StudentProfile {
  id                   String    @id @default(cuid())
  userId               String    @unique
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Personal Details
  phone                String?
  whatsapp             String?
  dateOfBirth          DateTime?
  nationality          String?
  city                 String?
  ukPostalCode         String?
  ukAddress            String?   @db.Text

  // Education Details
  highestQualification String?   // e.g., Bachelor's, Master's, PhD
  fieldOfStudy         String?
  university           String?
  graduationYear       Int?

  // UK Visa & Work Eligibility
  visaStatus           String?   // e.g., Graduate Visa, Skilled Worker, Student Visa
  visaExpiryDate       DateTime?
  workEligibility      Boolean   @default(false)
  hoursAllowedPerWeek  Int?      // e.g., 20 hrs/week on student visa

  // Job Preferences
  preferredJobTitles   String?   @db.Text // Stored as comma-separated or JSON string
  preferredLocations   String?
  availableFrom        DateTime?
  cvSummary            String?   @db.Text

  // Accommodation Preference
  accommodationNeeded  Boolean   @default(false)

  // Onboarding Progress Tracking
  onboardingCompleted  Boolean   @default(false)
  onboardingStep       Int       @default(1) // 1=Personal, 2=Education, 3=Visa, 4=Job, 5=Done

  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

// ================================================================
// LEAD CAPTURE — Public Website Contact/Interest Form
// ================================================================

/// Potential clients who fill the lead form before signing up
model Lead {
  id                String      @id @default(cuid())
  name              String
  email             String
  phone             String?
  whatsapp          String?
  city              String?
  interestedService ServiceType?
  message           String?     @db.Text
  status            LeadStatus  @default(NEW)
  source            String      @default("website") // website, referral, social, etc.

  // Admin management
  assignedToId      String?     // Admin who is following up
  followUpDate      DateTime?
  internalNotes     String?     @db.Text

  // Optional – if lead converts to user account
  convertedUserId   String?

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([email])
  @@index([status])
}

// ================================================================
// DOCUMENTS — CV / File Uploads via Cloudinary
// ================================================================

/// Files uploaded by students, stored in Cloudinary
model Document {
  id            String       @id @default(cuid())
  name          String       // Display name / original filename
  type          DocumentType @default(CV)
  url           String       // Cloudinary secure_url
  publicId      String?      // Cloudinary public_id (used for deletion)
  format        String?      // e.g., pdf, docx, jpg
  sizeKb        Int?

  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([userId])
  @@index([type])
}

// ================================================================
// SERVICE APPLICATIONS — Applications Tracker
// ================================================================

/// A student applies for a service (Job Placement, Visa Guidance, etc.)
model ServiceApplication {
  id            String            @id @default(cuid())
  serviceType   ServiceType
  status        ApplicationStatus @default(SUBMITTED)
  details       String?           @db.Text

  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Optional one-to-one for accommodation-type applications
  accommodationRequest AccommodationRequest?

  // Internal admin notes on this specific application
  adminNotes    AdminNote[]

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([userId])
  @@index([status])
  @@index([serviceType])
}

// ================================================================
// ACCOMMODATION REQUEST — Accommodation Tracker
// ================================================================

/// Detailed info for ACCOMMODATION_BOOKING applications
model AccommodationRequest {
  id               String             @id @default(cuid())
  applicationId    String             @unique
  application      ServiceApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  // Student Requirements
  preferredCity    String?
  preferredArea    String?
  budgetMin        Float?
  budgetMax        Float?
  currency         String             @default("GBP")
  moveInDate       DateTime?
  stayDuration     String?            // e.g., "3 months"
  numberOfRooms    Int?               @default(1)
  furnished        Boolean            @default(true)
  petsAllowed      Boolean            @default(false)
  specialRequests  String?            @db.Text

  // Admin-managed fields
  status           AccommodationStatus @default(PENDING)
  propertyLink     String?            // URL to confirmed property listing
  confirmedDate    DateTime?
  adminNotes       String?            @db.Text

  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

// ================================================================
// SUPPORT TICKETS — Help & Support Requests
// ================================================================

/// Student support tickets — admin replies and manages them
model SupportTicket {
  id          String              @id @default(cuid())
  subject     String
  message     String              @db.Text
  status      SupportTicketStatus @default(OPEN)
  priority    TicketPriority      @default(NORMAL)

  userId      String
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  replies     TicketReply[]

  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([userId])
  @@index([status])
  @@index([priority])
}

/// Replies to support tickets — from either student or admin
model TicketReply {
  id        String        @id @default(cuid())
  message   String        @db.Text
  isAdmin   Boolean       @default(false)

  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  userId    String
  user      User          @relation(fields: [userId], references: [id])

  createdAt DateTime      @default(now())

  @@index([ticketId])
}

// ================================================================
// PAYMENTS — Stripe / PayPal Integration
// ================================================================

/// One-time service fee payments — visible to student and admin
model Payment {
  id            String          @id @default(cuid())
  amount        Float
  currency      String          @default("GBP")
  status        PaymentStatus   @default(PENDING)
  provider      PaymentProvider
  providerTxnId String?         @unique  // Stripe payment_intent_id or PayPal order_id
  receiptUrl    String?                  // Stripe-generated receipt or PayPal confirmation URL

  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  serviceType   ServiceType?    // What service was paid for
  description   String?

  // Refund details
  refundedAt    DateTime?
  refundReason  String?

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([userId])
  @@index([status])
  @@index([providerTxnId])
}

// ================================================================
// ADMIN NOTES — Internal Private Notes
// ================================================================

/// Admins leave private notes on applications (not visible to student)
model AdminNote {
  id            String              @id @default(cuid())
  content       String              @db.Text

  adminId       String
  admin         User                @relation("AdminWhoWroteNote", fields: [adminId], references: [id])

  applicationId String?
  application   ServiceApplication? @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  createdAt     DateTime            @default(now())

  @@index([applicationId])
  @@index([adminId])
}

// ================================================================
// NOTIFICATIONS — Student Dashboard Alerts
// ================================================================

/// In-app notifications for students (e.g., application update, payment confirmed)
model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  link      String?          // Optional deep link (e.g., /dashboard/applications/123)

  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([isRead])
}

// ================================================================
// CMS CONTENT — Admin-Editable Website Content
// ================================================================

/// Simple key-value content store for admin to edit public website copy
model CmsContent {
  id          String   @id @default(cuid())
  key         String   @unique  // e.g., "home_hero_title", "pricing_intro"
  value       String   @db.Text
  page        String   // e.g., "home", "services", "pricing", "contact"
  label       String?  // Human-readable label for the admin CMS UI
  updatedBy   String?  // Admin userId who last changed it

  updatedAt   DateTime @updatedAt

  @@index([page])
}
